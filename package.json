{
  "name": "@cognis-digital/mcpscaffold",
  "version": "0.1.0",
  "description": "Scaffolder, validator, and test harness for local Model Context Protocol (MCP) servers, targeting MCP spec 2025-06-18.",
  "type": "module",
  "bin": {
    "mcpscaffold": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:test": "tsc -p tsconfig.test.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "prepublishOnly": "npm run build",
    "pretest": "npm run build && npm run build:test",
    "test": "node scripts/run-tests.mjs",
    "demo": "node demos/scaffold_and_smoke.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "scaffold",
    "generator",
    "validator",
    "json-schema",
    "json-rpc",
    "stdio",
    "cli"
  ],
  "author": "Cognis Digital",
  "license": "SEE LICENSE IN COCL",
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0"
  }
}
