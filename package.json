{
  "name": "@cognis-digital/mcpscaffold",
  "version": "0.1.0",
  "description": "Scaffolder, validator, and test harness for local Model Context Protocol (MCP) servers.",
  "type": "module",
  "bin": {
    "mcpscaffold": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "npm run build && node --test \"dist/test/*.test.js\""
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "scaffold",
    "validator",
    "json-schema",
    "cli"
  ],
  "author": "Cognis Digital",
  "license": "SEE LICENSE IN COCL",
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.11.0"
  }
}
